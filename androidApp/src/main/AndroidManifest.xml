<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Currency conversion (Settings → Regional) fetches FX rates over HTTPS; everything
         else in the app is offline-first and doesn't need this (AGENTS.md §12). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name="app.tally.TallyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tally">

        <activity
            android:name="app.tally.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Tally">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
